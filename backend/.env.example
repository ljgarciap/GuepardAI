# ─────────────────────────────────────────────────────
# GuepardAI - ENVIRONMENT CONFIGURATION EXAMPLE
# ─────────────────────────────────────────────────────

# --- DATABASE CONFIG ---
# (Docker Compose will use these to initialize the container)
DB_USER=postgres
DB_PASSWORD=secret_password_here
DB_NAME=guepard

# --- LLM PROVIDERS ---
OPENAI_API_KEY=sk-proj-....
MISTRAL_API_KEY=....
OPENROUTER_API_KEY=....

# --- GOOGLE CLOUD PLATFORM (For Vertex AI / Imagen 3) ---
GCP_PROJECT_ID=my-project-id
GCP_LOCATION=us-central1
# Path inside the container to your service account JSON
GOOGLE_APPLICATION_CREDENTIALS=/app/config/gcp-key.json

# --- API CONFIG ---
# (The host should be 'db' inside Docker Compose)
DATABASE_URL=postgresql://postgres:secret_password_here@db:5432/guepard
ALLOW_ORIGINS=http://localhost:3000,https://my-domain.com

# --- FEATURE FLAGS ---
DEBUG=False
LOG_LEVEL=INFO
